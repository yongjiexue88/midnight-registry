{
  "name": "midnight-registry",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1",
    "build": "next build",
    "start": "next start --hostname 127.0.0.1",
    "lint": "tsc --noEmit",
    "generate:audio": "node scripts/generate-midnight-audio.mjs",
    "generate:monsters": "node scripts/generate-midnight-monsters.mjs",
    "generate:assets": "npm run generate:audio && npm run generate:monsters",
    "verify:assets": "node scripts/verify-midnight-assets.mjs",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@supabase/supabase-js": "^2.86.1",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@storybook/nextjs": "^10.4.4",
    "@tailwindcss/postcss": "^4.1.17",
    "@types/node": "25.9.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.22",
    "playwright": "^1.60.0",
    "postcss": "^8.5.6",
    "storybook": "^10.4.4",
    "tailwindcss": "^4.1.17",
    "typescript": "5.9.3"
  }
}
